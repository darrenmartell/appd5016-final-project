@inject NavigationManager Navigation

<EditForm Model="FormModel" OnValidSubmit="HandleValidSubmitAsync" class="series-form-shell">
    <DataAnnotationsValidator />

    <section class="series-form-header">
        <span class="eyebrow">Series</span>
        <h1>@Heading</h1>
    </section>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="status-error">@ErrorMessage</div>
    }

    <ValidationSummary class="validation-summary" />

    <section class="series-form-section">
        <div class="series-form-section-label">Core Information</div>
        <div class="series-form-grid">
            <div class="series-form-field series-form-field-wide">
                <label class="field-label" for="series-title">Title *</label>
                <InputText id="series-title" class="field-input" @bind-Value="FormModel.Title" />
                <ValidationMessage For="() => FormModel.Title" class="field-error" />
            </div>

            <div class="series-form-field series-form-field-wide">
                <label class="field-label" for="series-plot">Plot Summary</label>
                <InputTextArea id="series-plot" class="field-input field-textarea" @bind-Value="FormModel.PlotSummary" />
            </div>

            <div class="series-form-field">
                <label class="field-label" for="series-runtime">Runtime (minutes)</label>
                <InputText id="series-runtime" class="field-input" @bind-Value="FormModel.RuntimeMinutes" />
            </div>

            <div class="series-form-field">
                <label class="field-label" for="series-year">Released Year</label>
                <InputText id="series-year" class="field-input" @bind-Value="FormModel.ReleasedYear" />
            </div>
        </div>
    </section>

    <section class="series-form-section">
        <div class="series-form-section-label">People</div>
        <div class="series-form-grid">
            @RenderTagEditor("Cast", FormModel.Cast, _castInput, value => _castInput = value, "Actor name")
            @RenderTagEditor("Directors", FormModel.Directors, _directorsInput, value => _directorsInput = value, "Director name")
            @RenderTagEditor("Producers", FormModel.Producers, _producersInput, value => _producersInput = value, "Producer name")
        </div>
    </section>

    <section class="series-form-section">
        <div class="series-form-section-label">Production</div>
        <div class="series-form-grid">
            @RenderTagEditor("Production Companies", FormModel.ProductionCompanies, _productionCompaniesInput, value => _productionCompaniesInput = value, "Company name")
            @RenderTagEditor("Countries", FormModel.Countries, _countriesInput, value => _countriesInput = value, "Country")
            @RenderTagEditor("Languages", FormModel.Languages, _languagesInput, value => _languagesInput = value, "Language")
            @RenderTagEditor("Genres", FormModel.Genres, _genresInput, value => _genresInput = value, "Genre")
        </div>
    </section>

    <section class="series-form-section">
        <div class="series-form-section-label">Ratings</div>
        <div class="series-form-grid series-ratings-grid">
            <div class="series-form-field">
                <label class="field-label" for="rating-imdb">IMDb</label>
                <InputText id="rating-imdb" class="field-input" @bind-Value="FormModel.Ratings.Imdb" />
            </div>
            <div class="series-form-field">
                <label class="field-label" for="rating-rotten">Rotten Tomatoes</label>
                <InputText id="rating-rotten" class="field-input" @bind-Value="FormModel.Ratings.RottenTomatoes" />
            </div>
            <div class="series-form-field">
                <label class="field-label" for="rating-meta">Metacritic</label>
                <InputText id="rating-meta" class="field-input" @bind-Value="FormModel.Ratings.Metacritic" />
            </div>
            <div class="series-form-field">
                <label class="field-label" for="rating-users">User Average</label>
                <InputText id="rating-users" class="field-input" @bind-Value="FormModel.Ratings.UserAverage" />
            </div>
        </div>
    </section>

    <section class="series-form-section">
        <div class="series-form-section-header">
            <div class="series-form-section-label">Episodes</div>
            <button type="button" class="button-secondary" @onclick="AddEpisode">Add Episode</button>
        </div>

        @if (FormModel.Episodes.Count == 0)
        {
            <div class="series-empty-state">No episodes added yet.</div>
        }
        else
        {
            <div class="series-episodes-stack">
                @for (var index = 0; index < FormModel.Episodes.Count; index++)
                {
                    var episode = FormModel.Episodes[index];

                    <div class="series-episode-row">
                        <div class="series-form-grid series-episode-grid">
                            <div class="series-form-field">
                                <label class="field-label">Episode #</label>
                                <input class="field-input" value="@(index + 1)" readonly />
                            </div>

                            <div class="series-form-field series-form-field-wide">
                                <label class="field-label">Episode Title</label>
                                <InputText class="field-input" @bind-Value="episode.EpisodeTitle" />
                            </div>

                            <div class="series-form-field">
                                <label class="field-label">Minutes</label>
                                <InputText class="field-input" @bind-Value="episode.RuntimeMinutes" />
                            </div>
                        </div>

                        <button type="button" class="episode-remove-button" @onclick="() => RemoveEpisode(index)">Remove</button>
                    </div>
                }
            </div>
        }
    </section>

    <div class="form-actions">
        <button type="submit" class="button-primary" disabled="@IsSubmitting">@(IsSubmitting ? "Saving..." : SubmitLabel)</button>
        <button type="button" class="button-secondary" @onclick="HandleCancel">Back</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public SeriesFormInput FormModel { get; set; } = default!;

    [Parameter]
    public string Heading { get; set; } = "Series Form";

    [Parameter]
    public string SubmitLabel { get; set; } = "Save Series";

    [Parameter]
    public bool IsSubmitting { get; set; }

    [Parameter]
    public string? ErrorMessage { get; set; }

    [Parameter]
    public EventCallback<SeriesUpsertRequest> OnSubmit { get; set; }

    private string _castInput = string.Empty;
    private string _directorsInput = string.Empty;
    private string _producersInput = string.Empty;
    private string _productionCompaniesInput = string.Empty;
    private string _countriesInput = string.Empty;
    private string _languagesInput = string.Empty;
    private string _genresInput = string.Empty;

    private async Task HandleValidSubmitAsync()
    {
        await OnSubmit.InvokeAsync(SeriesFormMapper.ToRequest(FormModel));
    }

    private void HandleCancel()
    {
        Navigation.NavigateTo("/admin/series");
    }

    private void AddEpisode()
    {
        FormModel.Episodes.Add(new SeriesEpisodeInput { EpisodeNumber = FormModel.Episodes.Count + 1 });
    }

    private void RemoveEpisode(int index)
    {
        FormModel.Episodes.RemoveAt(index);
    }

    private void AddTag(List<SeriesTagValueInput> tags, string currentValue, Action<string> setValue)
    {
        var normalizedValue = currentValue.Trim();

        if (string.IsNullOrWhiteSpace(normalizedValue))
        {
            return;
        }

        tags.Add(new SeriesTagValueInput { Value = normalizedValue });
        setValue(string.Empty);
    }

    private void RemoveTag(List<SeriesTagValueInput> tags, SeriesTagValueInput tag)
    {
        tags.Remove(tag);
    }

    private void HandleTagKeyDown(KeyboardEventArgs args, List<SeriesTagValueInput> tags, string currentValue, Action<string> setValue)
    {
        if (args.Key == "Enter")
        {
            AddTag(tags, currentValue, setValue);
        }
    }

    private RenderFragment RenderTagEditor(string label, List<SeriesTagValueInput> tags, string currentValue, Action<string> setValue, string placeholder) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "series-form-field");
        builder.OpenElement(sequence++, "label");
        builder.AddAttribute(sequence++, "class", "field-label");
        builder.AddContent(sequence++, label);
        builder.CloseElement();
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "tag-input-row");
        builder.OpenElement(sequence++, "input");
        builder.AddAttribute(sequence++, "class", "field-input");
        builder.AddAttribute(sequence++, "value", currentValue);
        builder.AddAttribute(sequence++, "placeholder", placeholder);
        builder.AddAttribute(sequence++, "oninput", EventCallback.Factory.CreateBinder<string>(this, value => setValue(value), currentValue));
        builder.AddAttribute(sequence++, "onkeydown", EventCallback.Factory.Create<KeyboardEventArgs>(this, args => HandleTagKeyDown(args, tags, currentValue, setValue)));
        builder.CloseElement();
        builder.OpenElement(sequence++, "button");
        builder.AddAttribute(sequence++, "type", "button");
        builder.AddAttribute(sequence++, "class", "button-primary tag-add-button");
        builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => AddTag(tags, currentValue, setValue)));
        builder.AddContent(sequence++, "+");
        builder.CloseElement();
        builder.CloseElement();

        if (tags.Count > 0)
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "tag-list");

            foreach (var tag in tags.ToList())
            {
                builder.OpenElement(sequence++, "span");
                builder.AddAttribute(sequence++, "class", "tag-chip");
                builder.AddContent(sequence++, tag.Value);
                builder.OpenElement(sequence++, "button");
                builder.AddAttribute(sequence++, "type", "button");
                builder.AddAttribute(sequence++, "class", "tag-chip-remove");
                builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => RemoveTag(tags, tag)));
                builder.AddContent(sequence++, "x");
                builder.CloseElement();
                builder.CloseElement();
            }

            builder.CloseElement();
        }

        builder.CloseElement();
    };
}