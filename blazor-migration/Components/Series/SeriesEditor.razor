@inject NavigationManager Navigation

<EditForm Model="FormModel" OnValidSubmit="HandleValidSubmitAsync" class="space-y-6">
    <DataAnnotationsValidator />

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="p-4 rounded-lg bg-red-900/20 border border-red-500/30 text-red-300 text-sm mb-6">@ErrorMessage</div>
    }

    <ValidationSummary class="p-4 rounded-lg bg-red-900/20 border border-red-500/30 text-red-300 text-sm mb-6 space-y-1" />

    <!-- Core Information Section -->
    <div class="border border-primary rounded-lg bg-surface-2 p-6">
        <h3 class="text-xl font-bold text-white mb-4">Core Information</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="col-span-1 md:col-span-2">
                <label class="block text-text-1 font-semibold mb-1" for="series-title">Title *</label>
                <InputText id="series-title" @bind-Value="FormModel.Title" class="w-full px-3 py-2 bg-[#232327] border border-primary rounded-lg focus:ring-2 focus:ring-accent/35 focus:border-accent text-white" />
                <ValidationMessage For="() => FormModel.Title" class="text-red-400 text-sm mt-1" />
            </div>

            <div class="col-span-1 md:col-span-2">
                <label class="block text-text-1 font-semibold mb-1" for="series-plot">Plot Summary</label>
                <InputTextArea id="series-plot" @bind-Value="FormModel.PlotSummary" class="w-full px-3 py-2 bg-[#232327] border border-primary rounded-lg focus:ring-2 focus:ring-accent/35 focus:border-accent text-white" rows="4" />
            </div>

            <div>
                <label class="block text-text-1 font-semibold mb-1" for="series-runtime">Runtime (minutes)</label>
                <InputText id="series-runtime" @bind-Value="FormModel.RuntimeMinutes" class="w-full px-3 py-2 bg-[#232327] border border-primary rounded-lg focus:ring-2 focus:ring-accent/35 focus:border-accent text-white" />
            </div>

            <div>
                <label class="block text-text-1 font-semibold mb-1" for="series-year">Released Year</label>
                <InputText id="series-year" @bind-Value="FormModel.ReleasedYear" class="w-full px-3 py-2 bg-[#232327] border border-primary rounded-lg focus:ring-2 focus:ring-accent/35 focus:border-accent text-white" />
            </div>
        </div>
    </div>

    <!-- People Section -->
    <div class="border border-primary rounded-lg bg-surface-2 p-6">
        <h3 class="text-xl font-bold text-white mb-4">People</h3>
        <div class="space-y-4">
            @RenderTagEditor("Cast", FormModel.Cast, _castInput, value => _castInput = value, "Actor name")
            @RenderTagEditor("Directors", FormModel.Directors, _directorsInput, value => _directorsInput = value, "Director name")
            @RenderTagEditor("Producers", FormModel.Producers, _producersInput, value => _producersInput = value, "Producer name")
        </div>
    </div>

    <!-- Production Section -->
    <div class="border border-primary rounded-lg bg-surface-2 p-6">
        <h3 class="text-xl font-bold text-white mb-4">Production</h3>
        <div class="space-y-4">
            @RenderTagEditor("Production Companies", FormModel.ProductionCompanies, _productionCompaniesInput, value => _productionCompaniesInput = value, "Company name")
            @RenderTagEditor("Countries", FormModel.Countries, _countriesInput, value => _countriesInput = value, "Country")
            @RenderTagEditor("Languages", FormModel.Languages, _languagesInput, value => _languagesInput = value, "Language")
            @RenderTagEditor("Genres", FormModel.Genres, _genresInput, value => _genresInput = value, "Genre")
        </div>
    </div>

    <!-- Ratings Section -->
    <div class="border border-primary rounded-lg bg-surface-2 p-6">
        <h3 class="text-xl font-bold text-white mb-4">Ratings</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-text-1 font-semibold mb-1" for="rating-imdb">IMDb</label>
                <InputText id="rating-imdb" @bind-Value="FormModel.Ratings.Imdb" class="w-full px-3 py-2 bg-[#232327] border border-primary rounded-lg focus:ring-2 focus:ring-accent/35 focus:border-accent text-white" />
            </div>
            <div>
                <label class="block text-text-1 font-semibold mb-1" for="rating-rotten">Rotten Tomatoes</label>
                <InputText id="rating-rotten" @bind-Value="FormModel.Ratings.RottenTomatoes" class="w-full px-3 py-2 bg-[#232327] border border-primary rounded-lg focus:ring-2 focus:ring-accent/35 focus:border-accent text-white" />
            </div>
            <div>
                <label class="block text-text-1 font-semibold mb-1" for="rating-meta">Metacritic</label>
                <InputText id="rating-meta" @bind-Value="FormModel.Ratings.Metacritic" class="w-full px-3 py-2 bg-[#232327] border border-primary rounded-lg focus:ring-2 focus:ring-accent/35 focus:border-accent text-white" />
            </div>
            <div>
                <label class="block text-text-1 font-semibold mb-1" for="rating-users">User Average</label>
                <InputText id="rating-users" @bind-Value="FormModel.Ratings.UserAverage" class="w-full px-3 py-2 bg-[#232327] border border-primary rounded-lg focus:ring-2 focus:ring-accent/35 focus:border-accent text-white" />
            </div>
        </div>
    </div>

    <!-- Episodes Section -->
    <div class="border border-primary rounded-lg bg-surface-2 p-6">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-xl font-bold text-white">Episodes</h3>
            <button type="button" class="px-4 py-2 bg-[#232327] text-text-1 border border-primary font-bold rounded-full hover:bg-[#2d2d31] transition-colors" @onclick="AddEpisode">Add Episode</button>
        </div>

        @if (FormModel.Episodes.Count == 0)
        {
            <p class="text-text-2 italic py-4">No episodes added yet.</p>
        }
        else
        {
            <div class="space-y-4">
                @for (var index = 0; index < FormModel.Episodes.Count; index++)
                {
                    var episode = FormModel.Episodes[index];

                    <div class="border border-primary/50 rounded-lg p-4 bg-surface-3">
                        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-3">
                            <div>
                                <label class="block text-text-1 font-semibold mb-1 text-sm">Episode #</label>
                                <input class="w-full px-3 py-2 bg-[#1a1a1c] border border-primary/30 rounded-lg text-white" value="@(index + 1)" readonly />
                            </div>

                            <div class="col-span-1 md:col-span-2">
                                <label class="block text-text-1 font-semibold mb-1 text-sm">Episode Title</label>
                                <InputText @bind-Value="episode.EpisodeTitle" class="w-full px-3 py-2 bg-[#232327] border border-primary rounded-lg focus:ring-2 focus:ring-accent/35 focus:border-accent text-white" />
                            </div>

                            <div>
                                <label class="block text-text-1 font-semibold mb-1 text-sm">Minutes</label>
                                <InputText @bind-Value="episode.RuntimeMinutes" class="w-full px-3 py-2 bg-[#232327] border border-primary rounded-lg focus:ring-2 focus:ring-accent/35 focus:border-accent text-white" />
                            </div>
                        </div>

                        <button type="button" class="px-3 py-1 bg-red-900/20 text-red-300 border border-red-500/30 text-sm font-semibold rounded hover:bg-red-900/40 transition-colors" @onclick="() => RemoveEpisode(index)">Remove Episode</button>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Form Actions -->
    <div class="flex gap-4">
        <button type="submit" class="px-6 py-2 bg-gradient-to-br from-[#e50914] to-[#b20710] text-white font-bold rounded-full hover:shadow-accent transition-all disabled:opacity-50" disabled="@IsSubmitting">@(IsSubmitting ? "Saving..." : SubmitLabel)</button>
        <button type="button" class="px-6 py-2 bg-[#232327] text-text-1 border border-primary font-bold rounded-full hover:bg-[#2d2d31] transition-colors" @onclick="HandleCancel">Back</button>
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public SeriesFormInput FormModel { get; set; } = default!;

    [Parameter]
    public string Heading { get; set; } = "Series Form";

    [Parameter]
    public string SubmitLabel { get; set; } = "Save Series";

    [Parameter]
    public bool IsSubmitting { get; set; }

    [Parameter]
    public string? ErrorMessage { get; set; }

    [Parameter]
    public EventCallback<SeriesUpsertRequest> OnSubmit { get; set; }

    private string _castInput = string.Empty;
    private string _directorsInput = string.Empty;
    private string _producersInput = string.Empty;
    private string _productionCompaniesInput = string.Empty;
    private string _countriesInput = string.Empty;
    private string _languagesInput = string.Empty;
    private string _genresInput = string.Empty;

    private async Task HandleValidSubmitAsync()
    {
        await OnSubmit.InvokeAsync(SeriesFormMapper.ToRequest(FormModel));
    }

    private void HandleCancel()
    {
        Navigation.NavigateTo("/admin/series");
    }

    private void AddEpisode()
    {
        FormModel.Episodes.Add(new SeriesEpisodeInput { EpisodeNumber = FormModel.Episodes.Count + 1 });
    }

    private void RemoveEpisode(int index)
    {
        FormModel.Episodes.RemoveAt(index);
    }

    private void AddTag(List<SeriesTagValueInput> tags, string currentValue, Action<string> setValue)
    {
        var normalizedValue = currentValue.Trim();

        if (string.IsNullOrWhiteSpace(normalizedValue))
        {
            return;
        }

        tags.Add(new SeriesTagValueInput { Value = normalizedValue });
        setValue(string.Empty);
    }

    private void RemoveTag(List<SeriesTagValueInput> tags, SeriesTagValueInput tag)
    {
        tags.Remove(tag);
    }

    private void HandleTagKeyDown(KeyboardEventArgs args, List<SeriesTagValueInput> tags, string currentValue, Action<string> setValue)
    {
        if (args.Key == "Enter")
        {
            AddTag(tags, currentValue, setValue);
        }
    }

    private RenderFragment RenderTagEditor(string label, List<SeriesTagValueInput> tags, string currentValue, Action<string> setValue, string placeholder) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "series-form-field");
        builder.OpenElement(sequence++, "label");
        builder.AddAttribute(sequence++, "class", "field-label");
        builder.AddContent(sequence++, label);
        builder.CloseElement();
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "tag-input-row");
        builder.OpenElement(sequence++, "input");
        builder.AddAttribute(sequence++, "class", "field-input");
        builder.AddAttribute(sequence++, "value", currentValue);
        builder.AddAttribute(sequence++, "placeholder", placeholder);
        builder.AddAttribute(sequence++, "oninput", EventCallback.Factory.CreateBinder<string>(this, value => setValue(value), currentValue));
        builder.AddAttribute(sequence++, "onkeydown", EventCallback.Factory.Create<KeyboardEventArgs>(this, args => HandleTagKeyDown(args, tags, currentValue, setValue)));
        builder.CloseElement();
        builder.OpenElement(sequence++, "button");
        builder.AddAttribute(sequence++, "type", "button");
        builder.AddAttribute(sequence++, "class", "button-primary tag-add-button");
        builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => AddTag(tags, currentValue, setValue)));
        builder.AddContent(sequence++, "+");
        builder.CloseElement();
        builder.CloseElement();

        if (tags.Count > 0)
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "tag-list");

            foreach (var tag in tags.ToList())
            {
                builder.OpenElement(sequence++, "span");
                builder.AddAttribute(sequence++, "class", "tag-chip");
                builder.AddContent(sequence++, tag.Value);
                builder.OpenElement(sequence++, "button");
                builder.AddAttribute(sequence++, "type", "button");
                builder.AddAttribute(sequence++, "class", "tag-chip-remove");
                builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => RemoveTag(tags, tag)));
                builder.AddContent(sequence++, "x");
                builder.CloseElement();
                builder.CloseElement();
            }

            builder.CloseElement();
        }

        builder.CloseElement();
    };
}