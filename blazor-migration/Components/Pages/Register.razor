@page "/register"
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Register</PageTitle>

<section class="page-shell auth-card">
    <span class="eyebrow">Account access</span>
    <h1>Register</h1>
    <p class="muted">Create an account to access the admin dashboard.</p>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="status-error">@_errorMessage</div>
    }

    <EditForm Model="_model" OnValidSubmit="HandleRegisterAsync" class="form-stack">
        <DataAnnotationsValidator />

        <div class="form-field">
            <label class="field-label" for="firstName">First Name</label>
            <InputText id="firstName" class="field-input" @bind-Value="_model.FirstName" />
            <ValidationMessage For="() => _model.FirstName" class="field-error" />
        </div>

        <div class="form-field">
            <label class="field-label" for="lastName">Last Name</label>
            <InputText id="lastName" class="field-input" @bind-Value="_model.LastName" />
            <ValidationMessage For="() => _model.LastName" class="field-error" />
        </div>

        <div class="form-field">
            <label class="field-label" for="registerEmail">Email</label>
            <InputText id="registerEmail" class="field-input" @bind-Value="_model.Email" />
            <ValidationMessage For="() => _model.Email" class="field-error" />
        </div>

        <div class="form-field">
            <label class="field-label" for="registerPassword">Password</label>
            <InputText id="registerPassword" type="password" class="field-input" @bind-Value="_model.Password" />
            <ValidationMessage For="() => _model.Password" class="field-error" />
        </div>

        <div class="form-field">
            <label class="field-label" for="confirmPassword">Confirm Password</label>
            <InputText id="confirmPassword" type="password" class="field-input" @bind-Value="_model.ConfirmPassword" />
            <ValidationMessage For="() => _model.ConfirmPassword" class="field-error" />
        </div>

        <ValidationSummary class="validation-summary" />

        <div class="form-actions">
            <button class="button-primary" type="submit" disabled="@_isSubmitting">@(_isSubmitting ? "Registering..." : "Submit")</button>
            <NavLink class="button-secondary" href="/login">Login</NavLink>
        </div>
    </EditForm>
</section>

@code {
    private readonly RegisterInput _model = new();
    private string? _errorMessage;
    private bool _isSubmitting;

    private async Task HandleRegisterAsync()
    {
        _errorMessage = null;
        _isSubmitting = true;

        try
        {
            await AuthService.RegisterAsync(new RegisterRequest(_model.FirstName, _model.LastName, _model.Email, _model.Password));
            Navigation.NavigateTo("/admin/home", replace: true);
        }
        catch (InvalidOperationException exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}