@page "/changepassword"
@layout AdminLayout
@inject NavigationManager Navigation

<PageTitle>Change Password</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="max-w-2xl mx-auto px-6 py-8">
            <section class="p-8 bg-[#222] rounded-2xl border border-[#333] shadow-[0_1.25rem_2.75rem_rgba(0,0,0,0.28)]">
                <span class="inline-block mb-3 px-2 py-1 text-[0.72rem] font-bold text-[#ff7b84] uppercase tracking-widest">Account security</span>
                <h1 class="text-4xl font-bold text-white mb-2">Change Password</h1>
                <p class="text-[#a0a0a5] mb-6">The frontend route is in place, but the backend API does not expose a change-password endpoint yet.</p>

                <div class="p-4 rounded-lg bg-blue-900/20 border border-blue-500/30 text-blue-300 text-sm mb-6">
                    Change password is currently unavailable. Add the backend route first, then this screen can be connected end to end.
                </div>

                <div class="flex gap-4">
                    <button class="px-6 py-2 bg-[#232327] text-[#d0d0d2] border border-[#333] font-bold rounded-full hover:bg-[#2d2d31] transition-colors" 
                            type="button" 
                            @onclick="NavigateBack">
                        Back
                    </button>
                </div>
            </section>
        </div>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private void NavigateBack()
    {
        Navigation.NavigateTo("/admin/home");
    }
}
