@page "/changepassword"
@layout AdminLayout
@inject NavigationManager Navigation

<PageTitle>Change Password</PageTitle>

<AuthorizeView>
    <Authorized Context="authState">
        <section class="page-shell auth-card">
            <span class="eyebrow">Account security</span>
            <h1>Change Password</h1>
            <p class="muted">The frontend route is in place, but the backend API does not expose a change-password endpoint yet.</p>

            <div class="status-info">
                Change password is currently unavailable. Add the backend route first, then this screen can be connected end to end.
            </div>

            <div class="form-actions">
                <button class="button-secondary" type="button" @onclick="NavigateBack">Back</button>
            </div>
        </section>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private void NavigateBack()
    {
        Navigation.NavigateTo("/admin/home");
    }
}