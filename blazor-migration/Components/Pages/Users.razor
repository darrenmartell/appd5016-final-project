@page "/admin/users"
@layout AdminLayout
@inject IUsersService UsersService

<PageTitle>User Management</PageTitle>

<AuthorizeView>
    <Authorized>
        <section class="page-shell panel-shell">
            <span class="eyebrow">Phase 3 users slice</span>
            <h1>User Management</h1>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="status-error">@_errorMessage</div>
            }
            else if (_isLoading)
            {
                <div class="status-info">Loading users...</div>
            }
            else if (_users.Count == 0)
            {
                <div class="status-info">No users found.</div>
            }
            else
            {
                <div class="users-table-wrap">
                    <table class="users-table">
                        <thead>
                            <tr>
                                <th>First Name</th>
                                <th>Last Name</th>
                                <th>Email</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in _users)
                            {
                                <tr>
                                    <td>@user.FirstName</td>
                                    <td>@user.LastName</td>
                                    <td>@user.Email</td>
                                    <td>
                                        <div class="users-actions">
                                            <a class="button-secondary button-link" href="@($"/admin/users/{user.Id}/details")">Details</a>
                                            <a class="button-secondary button-link" href="@($"/admin/users/{user.Id}/delete")">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private readonly List<UserSummary> _users = [];
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var users = await UsersService.GetUsersAsync();
            _users.Clear();
            _users.AddRange(users);
        }
        catch (InvalidOperationException exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}