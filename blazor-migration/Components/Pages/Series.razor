@page "/admin/series"
@layout AdminLayout
@inject ISeriesService SeriesService

<PageTitle>Series</PageTitle>

<AuthorizeView>
    <Authorized>
        <section class="page-shell panel-shell">
            <span class="eyebrow">Phase 4 series slice</span>
            <h1>Series Management</h1>

            <div class="form-actions series-list-actions">
                <a class="button-primary button-link" href="/admin/series/add">Add Series</a>
            </div>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="status-error">@_errorMessage</div>
            }
            else if (_isLoading)
            {
                <div class="status-info">Loading series...</div>
            }
            else if (_series.Count == 0)
            {
                <div class="status-info">No series found.</div>
            }
            else
            {
                <div class="users-table-wrap">
                    <table class="users-table series-table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Plot Summary</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _series)
                            {
                                <tr>
                                    <td>@item.Title</td>
                                    <td>@item.PlotSummary</td>
                                    <td>
                                        <div class="users-actions">
                                            <a class="button-primary button-link series-action-button" href="@($"/admin/series/{item.Id}/update")">Edit</a>
                                            <a class="button-secondary button-link" href="@($"/admin/series/{item.Id}/delete")">Delete</a>
                                            <a class="button-secondary button-link" href="@($"/admin/series/{item.Id}/details")">Details</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private readonly List<SeriesRecord> _series = [];
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var series = await SeriesService.GetSeriesAsync();
            _series.Clear();
            _series.AddRange(series);
        }
        catch (InvalidOperationException exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}