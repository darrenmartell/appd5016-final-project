@page "/admin/series/{Id}/delete"
@layout AdminLayout
@inject ISeriesService SeriesService
@inject NavigationManager Navigation

<PageTitle>Delete Series</PageTitle>

<AuthorizeView>
    <Authorized>
        <section class="page-shell panel-shell danger-card">
            <span class="eyebrow">Series</span>
            <h1>Delete Series</h1>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="status-error">@_errorMessage</div>
            }
            else if (_isLoading)
            {
                <div class="status-info">Loading series record...</div>
            }
            else if (_seriesItem is null)
            {
                <div class="status-info">Series not found.</div>
            }
            else
            {
                <div class="details-grid">
                    <div class="detail-row">
                        <span class="detail-label">ID</span>
                        <span>@_seriesItem.Id</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Name</span>
                        <span>@_seriesItem.Title</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_seriesItem.PlotSummary))
                    {
                        <div class="detail-row">
                            <span class="detail-label">Plot Summary</span>
                            <span>@_seriesItem.PlotSummary</span>
                        </div>
                    }
                </div>

                <div class="form-actions">
                    <button type="button" class="button-primary" disabled="@_isDeleting" @onclick="DeleteAsync">@(_isDeleting ? "Deleting..." : "Delete Series")</button>
                    <button type="button" class="button-secondary" @onclick="GoBack">Back to Series List</button>
                </div>
            }
        </section>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private SeriesRecord? _seriesItem;
    private bool _isLoading = true;
    private bool _isDeleting;
    private string? _errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var series = await SeriesService.GetSeriesAsync();
            _seriesItem = series.FirstOrDefault(item => item.Id == Id);
        }
        catch (InvalidOperationException exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (_seriesItem is null)
        {
            return;
        }

        _isDeleting = true;
        _errorMessage = null;

        try
        {
            await SeriesService.DeleteSeriesAsync(_seriesItem.Id);
            Navigation.NavigateTo("/admin/series", replace: true);
        }
        catch (InvalidOperationException exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/admin/series");
    }
}