@page "/login"
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<div class="min-h-screen flex items-center justify-center bg-[#141414]">
    <section class="max-w-md w-full mx-auto my-8 p-8 bg-surface-2 rounded-2xl border border-primary shadow-netflix">
        <span class="inline-block mb-3 px-2 py-1 text-eyebrow text-[#ff7b84] uppercase tracking-widest">Account access</span>
        <h1 class="text-4xl font-bold text-white mb-2">Login</h1>
        <p class="text-text-2 mb-6">Sign in with your account to access the admin dashboard.</p>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="mb-4 p-3 rounded-lg bg-red-900/20 border border-red-500/30 text-red-300 text-sm">
                @_errorMessage
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleLoginAsync" class="flex flex-col gap-4">
            <DataAnnotationsValidator />

            <div class="flex flex-col gap-2">
                <label class="font-semibold text-text-1 text-sm" for="email">Email</label>
                <InputText id="email" 
                          class="w-full px-3 py-2 bg-[#232327] border border-primary rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-accent/35 focus:border-accent" 
                          @bind-Value="_model.Email" />
                <ValidationMessage For="() => _model.Email" class="text-red-500 text-xs" />
            </div>

            <div class="flex flex-col gap-2">
                <label class="font-semibold text-text-1 text-sm" for="password">Password</label>
                <InputText id="password" 
                          type="password" 
                          class="w-full px-3 py-2 bg-[#232327] border border-primary rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-accent/35 focus:border-accent" 
                          @bind-Value="_model.Password" />
                <ValidationMessage For="() => _model.Password" class="text-red-500 text-xs" />
            </div>

            <ValidationSummary class="p-3 rounded-lg bg-surface-3 border border-red-500 text-red-500 text-sm" />

            <div class="flex gap-4 mt-6 justify-end">
                <button class="px-6 py-2 bg-gradient-to-br from-[#e50914] to-[#b20710] text-white font-bold rounded-full hover:shadow-accent transition-all disabled:opacity-50" 
                        type="submit" 
                        disabled="@_isSubmitting">
                    @(_isSubmitting ? "Logging in..." : "Login")
                </button>
                <NavLink class="px-6 py-2 bg-[#232327] text-text-1 border border-primary font-bold rounded-full hover:bg-[#2d2d31] transition-colors" 
                         href="/register">
                    Register
                </NavLink>
            </div>
        </EditForm>
    </section>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private readonly LoginInput _model = new();
    private string? _errorMessage;
    private bool _isSubmitting;

    private async Task HandleLoginAsync()
    {
        _errorMessage = null;
        _isSubmitting = true;

        try
        {
            await AuthService.LoginAsync(new LoginRequest(_model.Email, _model.Password));
            Navigation.NavigateTo(GetReturnTarget(), replace: true);
        }
        catch (InvalidOperationException exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private string GetReturnTarget()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl) || !ReturnUrl.StartsWith('/'))
        {
            return "/admin/home";
        }

        return ReturnUrl.StartsWith("/login", StringComparison.OrdinalIgnoreCase)
            ? "/admin/home"
            : ReturnUrl;
    }
}
