@page "/admin/series/{Id}/update"
@layout AdminLayout
@inject ISeriesService SeriesService
@inject NavigationManager Navigation

<PageTitle>Update Series</PageTitle>

<AuthorizeView>
    <Authorized>
        <section class="page-shell panel-shell">
            @if (!string.IsNullOrWhiteSpace(_loadError))
            {
                <div class="status-error">@_loadError</div>
            }
            else if (_isLoading)
            {
                <div class="status-info">Loading series for edit...</div>
            }
            else if (_formModel is null)
            {
                <div class="status-info">Series not found.</div>
            }
            else
            {
                <SeriesEditor FormModel="_formModel"
                              Heading="Edit Series"
                              SubmitLabel="Update Series"
                              IsSubmitting="_isSubmitting"
                              ErrorMessage="_submitError"
                              OnSubmit="HandleSubmitAsync" />
            }
        </section>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private SeriesFormInput? _formModel;
    private bool _isLoading = true;
    private bool _isSubmitting;
    private string? _loadError;
    private string? _submitError;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _loadError = null;
        _submitError = null;

        try
        {
            var series = await SeriesService.GetSeriesAsync();
            var currentSeries = series.FirstOrDefault(item => item.Id == Id);
            _formModel = currentSeries is null ? null : SeriesFormMapper.ToInput(currentSeries);
        }
        catch (InvalidOperationException exception)
        {
            _loadError = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleSubmitAsync(SeriesUpsertRequest request)
    {
        _isSubmitting = true;
        _submitError = null;

        try
        {
            await SeriesService.UpdateSeriesAsync(Id, request);
            Navigation.NavigateTo("/admin/series", replace: true);
        }
        catch (InvalidOperationException exception)
        {
            _submitError = exception.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}