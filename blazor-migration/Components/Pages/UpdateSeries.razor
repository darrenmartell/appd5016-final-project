@page "/admin/series/{Id}/update"
@layout AdminLayout
@inject ISeriesService SeriesService
@inject NavigationManager Navigation

<PageTitle>Update Series</PageTitle>

<AuthorizeView>
    <Authorized>
        <section class="max-w-5xl mx-auto px-6 py-6 my-6">
            <span class="inline-block mb-3 px-2 py-1 text-eyebrow text-[#ff7b84] uppercase tracking-widest\">Series</span>
            <h1 class="text-4xl font-bold text-white mb-6\">Edit Series</h1>
            
            @if (!string.IsNullOrWhiteSpace(_loadError))
            {
                <div class="p-4 rounded-lg bg-red-900/20 border border-red-500/30 text-red-300 text-sm mb-6\">@_loadError</div>
            }
            else if (_isLoading)
            {
                <div class="p-4 rounded-lg bg-blue-900/20 border border-blue-500/30 text-blue-300 text-sm mb-6\">Loading series for edit...</div>
            }
            else if (_formModel is null)
            {
                <div class="p-4 rounded-lg bg-blue-900/20 border border-blue-500/30 text-blue-300 text-sm mb-6\">Series not found.</div>
            }
            else
            {
                <SeriesEditor FormModel="_formModel"
                              Heading="Edit Series"
                              SubmitLabel="Update Series"
                              IsSubmitting="_isSubmitting"
                              ErrorMessage="_submitError"
                              OnSubmit="HandleSubmitAsync" />
            }
        </section>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private SeriesFormInput? _formModel;
    private bool _isLoading = true;
    private bool _isSubmitting;
    private string? _loadError;
    private string? _submitError;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _loadError = null;
        _submitError = null;

        try
        {
            var series = await SeriesService.GetSeriesAsync();
            var currentSeries = series.FirstOrDefault(item => item.Id == Id);
            _formModel = currentSeries is null ? null : SeriesFormMapper.ToInput(currentSeries);
        }
        catch (InvalidOperationException exception)
        {
            _loadError = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleSubmitAsync(SeriesUpsertRequest request)
    {
        _isSubmitting = true;
        _submitError = null;

        try
        {
            await SeriesService.UpdateSeriesAsync(Id, request);
            Navigation.NavigateTo("/admin/series", replace: true);
        }
        catch (InvalidOperationException exception)
        {
            _submitError = exception.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}