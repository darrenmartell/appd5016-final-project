@page "/admin/users/{Id}/details"
@layout AdminLayout
@inject IUsersService UsersService
@inject NavigationManager Navigation

<PageTitle>User Details</PageTitle>

<AuthorizeView>
    <Authorized>
        <section class="max-w-5xl mx-auto px-6 py-6 my-6">
            <span class="inline-block mb-3 px-2 py-1 text-eyebrow text-[#ff7b84] uppercase tracking-widest">Users</span>
            <h1 class="text-4xl font-bold text-white mb-6">User Details</h1>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="p-4 rounded-lg bg-red-900/20 border border-red-500/30 text-red-300 text-sm mb-6">@_errorMessage</div>
            }
            else if (_isLoading)
            {
                <div class="p-4 rounded-lg bg-blue-900/20 border border-blue-500/30 text-blue-300 text-sm mb-6">Loading user details...</div>
            }
            else if (_user is null)
            {
                <div class="p-4 rounded-lg bg-blue-900/20 border border-blue-500/30 text-blue-300 text-sm mb-6">User not found.</div>
            }
            else
            {
                <div class="space-y-4">
                    <div class="flex justify-between items-start p-3 border-b border-primary">
                        <span class="text-text-2 font-semibold min-w-max">ID</span>
                        <span>@_user.Id</span>
                    </div>
                    <div class="flex justify-between items-start p-3 border-b border-primary">
                        <span class="text-text-2 font-semibold min-w-max">Name</span>
                        <span>@_user.FirstName @_user.LastName</span>
                    </div>
                    <div class="flex justify-between items-start p-3 border-b border-primary">
                        <span class="text-text-2 font-semibold min-w-max">Email</span>
                        <span>@_user.Email</span>
                    </div>
                </div>
            }

            <div class="flex gap-4 mt-6">
                <button class="px-6 py-2 bg-[#232327] text-text-1 border border-primary font-bold rounded-full hover:bg-[#2d2d31] transition-colors" type="button" @onclick="GoBack">Back to Users List</button>
            </div>
        </section>
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private UserSummary? _user;
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var users = await UsersService.GetUsersAsync();
            _user = users.FirstOrDefault(item => item.Id == Id);
        }
        catch (InvalidOperationException exception)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/admin/users");
    }
}