@page "/"
@inject NavigationManager Navigation

<PageTitle>Redirecting</PageTitle>

<section class="page-shell">
    <span class="eyebrow">Redirect</span>
    <h1>Redirecting to the admin home route</h1>
    <p class="muted">Taking you to the admin home route.</p>
</section>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Navigation.NavigateTo("/admin/home", replace: true);
        }
    }
}