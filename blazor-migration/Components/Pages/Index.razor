@page "/"
@inject NavigationManager Navigation

<PageTitle>Redirecting</PageTitle>

<section class="max-w-2xl mx-auto px-6 py-8">
    <span class="inline-block mb-3 px-2 py-1 text-eyebrow text-[#ff7b84] uppercase tracking-widest">Redirect</span>
    <h1 class="text-4xl font-bold text-white mb-2">Redirecting to the admin home route</h1>
    <p class="text-text-2">Taking you to the admin home route.</p>
</section>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Navigation.NavigateTo("/admin/home", replace: true);
        }
    }
}