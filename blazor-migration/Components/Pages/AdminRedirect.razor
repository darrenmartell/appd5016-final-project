@page "/admin"
@inject NavigationManager Navigation

<PageTitle>Redirecting</PageTitle>

<section class="page-shell">
    <span class="eyebrow">Redirect</span>
    <h1>Redirecting to the admin home route</h1>
    <p class="muted">Phase 1 preserves the React route behavior from `/admin` to `/admin/home`.</p>
</section>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Navigation.NavigateTo("/admin/home", replace: true);
        }
    }
}