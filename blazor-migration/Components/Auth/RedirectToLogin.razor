@inject NavigationManager Navigation

<section class="max-w-md mx-auto my-8 p-8 bg-[#222] border border-[#333] rounded-2xl shadow-[0_1.25rem_2.75rem_rgba(0,0,0,0.28)]">
    <span class="inline-block mb-3 px-2 py-1 text-[0.72rem] font-bold text-[#ff7b84] uppercase tracking-widest">Authorization required</span>
    <h1 class="text-3xl font-bold text-white mb-3">Redirecting to login</h1>
    <p class="text-[#a0a0a5]">This page requires an authenticated account. Redirecting you to the login screen now.</p>
</section>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var relativePath = "/" + Navigation.ToBaseRelativePath(Navigation.Uri);

        if (relativePath.StartsWith("/login", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var target = $"/login?returnUrl={Uri.EscapeDataString(relativePath)}";
        Navigation.NavigateTo(target, replace: true);
    }
}