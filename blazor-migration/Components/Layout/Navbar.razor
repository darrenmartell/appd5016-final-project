@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject SeriesSearchState SeriesSearchState

<header class="sticky top-0 z-20 w-full bg-[#141414] border-b border-primary backdrop-blur-sm px-6 py-4">
    <nav class="flex items-center justify-between">
        <!-- Logo and brand -->
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-gradient-to-br from-[#ff3d47] to-[#b20710] rounded-full shadow-md"></div>
            <div class="flex flex-col">
                <div class="text-xl font-bold text-white">Harlen Coben Netflix Series</div>
                <div class="text-xs text-text-2 font-medium">Admin dashboard</div>
            </div>
        </div>

        <!-- Actions -->
        <div>
            <AuthorizeView>
                <Authorized Context="authState">
                    <div class="flex items-center gap-6 text-text-2">
                        <!-- Search input (hidden on mobile) -->
                        @if (ShowSearch)
                        {
                            <input class="hidden md:block px-3 py-2 bg-[#333] border border-[#444] text-white rounded-md focus:outline-none focus:ring focus:border-accent placeholder:text-[#888]"
                                   type="text"
                                   placeholder="Search series"
                                   value="@SeriesSearchState.SearchTerm"
                                   @oninput="HandleSearchInput" />
                        }

                        <!-- Account menu -->
                        <div class="flex items-center gap-4">
                            <span class="hidden md:inline px-3 py-1 bg-[#2a2a2d] text-text-1 rounded-full text-sm font-medium">
                                @GetDisplayName(authState.User)
                            </span>
                            <NavLink href="/changepassword" 
                                     class="text-text-2 hover:text-white transition-colors text-sm" 
                                     ActiveClass="text-white font-semibold" 
                                     Match="NavLinkMatch.All">
                                Change Password
                            </NavLink>
                            <button type="button" 
                                    class="text-text-2 hover:text-white transition-colors text-sm font-medium" 
                                    @onclick="HandleLogoutAsync">
                                Logout
                            </button>
                        </div>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <nav class="flex items-center gap-6" aria-label="Primary links">
                        <NavLink href="/login" 
                                 class="text-text-2 hover:text-white transition-colors text-sm font-medium" 
                                 ActiveClass="text-white font-semibold" 
                                 Match="NavLinkMatch.All">
                            Login
                        </NavLink>
                        <NavLink href="/register" 
                                 class="text-text-2 hover:text-white transition-colors text-sm font-medium" 
                                 ActiveClass="text-white font-semibold" 
                                 Match="NavLinkMatch.All">
                            Register
                        </NavLink>
                    </nav>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>
</header>

@code {
    [Parameter]
    public bool ShowSearch { get; set; }

    private async Task HandleLogoutAsync()
    {
        await AuthService.LogoutAsync();
        SeriesSearchState.SetSearchTerm(string.Empty);
        Navigation.NavigateTo("/login", replace: true);
    }

    private void HandleSearchInput(ChangeEventArgs args)
    {
        SeriesSearchState.SetSearchTerm(args.Value?.ToString());
    }

    private static string GetDisplayName(ClaimsPrincipal user)
    {
        return user.FindFirst(ClaimTypes.Email)?.Value
            ?? user.Identity?.Name
            ?? "Signed in";
    }
}