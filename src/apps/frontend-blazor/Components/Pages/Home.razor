@page "/admin/home"
@layout AdminLayout
@implements IDisposable
@inject ISeriesService SeriesService
@inject SeriesSearchState SeriesSearchState
@inject NavigationManager Navigation

<PageTitle>Dashboard</PageTitle>

<AuthorizeView>
	<Authorized>
		<section class="max-w-5xl mx-auto px-6 py-6 my-6">
			<h1 class="text-2xl py-4 font-bold text-white">Dashboard</h1>

			@if (!string.IsNullOrWhiteSpace(_errorMessage))
			{
				<p class="text-[#ff6b6b]">@_errorMessage</p>
			}
			else if (_isLoading)
			{
				<p class="text-[#b3b3b3]">Loading series...</p>
			}
			else if (FilteredSeries.Count == 0)
			{
				<p class="text-[#b3b3b3]">No series found.</p>
			}
			else
			{
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
					@foreach (var item in FilteredSeries)
					{
					<button type="button" class="h-full w-full flex flex-col justify-start border border-[#333] rounded-lg overflow-hidden bg-[#222] cursor-pointer hover:border-[#e50914] hover:shadow-[0_4px_16px_rgba(229,9,20,0.15)] transition-all text-left align-top" @onclick="() => OpenDetails(item.Id)">
						<div class="px-5 pt-4 pb-3 border-b border-[#333]">
							<h2 class="text-[18px] font-bold text-white leading-[1.3] mb-0">@(string.IsNullOrWhiteSpace(item.Title) ? "Untitled" : item.Title)</h2>
							<div class="flex gap-3 mt-1.5 text-[#888] text-[13px]">
									@if (item.ReleasedYear is not null)
									{
										<span>@item.ReleasedYear</span>
									}
									@if (item.RuntimeMinutes is not null)
									{
										<span>@item.RuntimeMinutes min</span>
									}
									@if (item.Episodes.Count > 0)
									{
										<span>@item.Episodes.Count ep@(item.Episodes.Count == 1 ? string.Empty : "s")</span>
									}
								</div>
							</div>

							@if (item.Genres.Count > 0)
							{
								<div class="px-5 pt-2.5 flex flex-wrap gap-1">
									@foreach (var genre in item.Genres)
									{
										<span class="py-[2px] px-[10px] bg-[#e50914] text-white text-[11px] font-semibold rounded-[12px]">@genre</span>
									}
								</div>
							}

							@if (!string.IsNullOrWhiteSpace(item.PlotSummary))
							{
								<div class="px-5 py-2 text-[#b3b3b3] text-sm leading-relaxed whitespace-pre-line">@item.PlotSummary</div>
							}

							@if (HasVisibleRatings(item.Ratings))
							{
								<div class="px-5 pt-2 pb-4 flex flex-wrap gap-3">
									@if (item.Ratings.Imdb is not null)
									{
										<div class="text-center"><div class="text-[10px] uppercase tracking-[0.05em] text-[#888]">IMDb</div><div class="text-base font-bold text-[#f5c518]">@item.Ratings.Imdb</div></div>
									}
									@if (item.Ratings.RottenTomatoes is not null)
									{
										<div class="text-center"><div class="text-[10px] uppercase tracking-[0.05em] text-[#888]">RT</div><div class="text-base font-bold text-[#fa320a]">@item.Ratings.RottenTomatoes</div></div>
									}
									@if (item.Ratings.Metacritic is not null)
									{
										<div class="text-center"><div class="text-[10px] uppercase tracking-[0.05em] text-[#888]">MC</div><div class="text-base font-bold text-[#ffcc34]">@item.Ratings.Metacritic</div></div>
									}
									@if (item.Ratings.UserAverage is not null)
									{
										<div class="text-center"><div class="text-[10px] uppercase tracking-[0.05em] text-[#888]">Users</div><div class="text-base font-bold text-white">@item.Ratings.UserAverage</div></div>
									}
								</div>
							}

							@if (item.Cast.Count > 0)
							{
								<div class="px-5 pb-4 text-[#666] text-xs">
									@string.Join(", ", item.Cast.Take(3))@(item.Cast.Count > 3 ? $" +{item.Cast.Count - 3} more" : string.Empty)
								</div>
							}
						</button>
					}
				</div>
			}
		</section>
	</Authorized>
	<NotAuthorized>
		<RedirectToLogin />
	</NotAuthorized>
</AuthorizeView>

@code {
	private readonly List<SeriesRecord> _series = [];
	private bool _isLoading = true;
	private string? _errorMessage;

	private IReadOnlyList<SeriesRecord> FilteredSeries => string.IsNullOrWhiteSpace(SeriesSearchState.SearchTerm)
		? _series
		: _series.Where(MatchesSearch).ToList();

	protected override async Task OnInitializedAsync()
	{
		SeriesSearchState.SearchChanged += HandleSearchChanged;

		try
		{
			var series = await SeriesService.GetSeriesAsync();
			_series.Clear();
			_series.AddRange(series);
		}
		catch (InvalidOperationException exception)
		{
			_errorMessage = exception.Message;
		}
		finally
		{
			_isLoading = false;
		}
	}

	public void Dispose()
	{
		SeriesSearchState.SearchChanged -= HandleSearchChanged;
	}

	private void OpenDetails(string id)
	{
		Navigation.NavigateTo($"/admin/series/{id}/details");
	}

	private bool MatchesSearch(SeriesRecord item)
	{
		var term = SeriesSearchState.SearchTerm.Trim().ToLowerInvariant();
		var ratingsKeys = GetRatingsKeys(item.Ratings);
		var episodeText = item.Episodes.Select(episode => $"{episode.EpisodeTitle} {episode.RuntimeMinutes}");
		var combined = string.Join(' ',
			new[]
			{
				item.Title,
				item.PlotSummary ?? string.Empty,
				item.ReleasedYear?.ToString() ?? string.Empty,
				item.RuntimeMinutes?.ToString() ?? string.Empty,
				string.Join(' ', item.Genres),
				string.Join(' ', item.Countries),
				string.Join(' ', item.Languages),
				string.Join(' ', item.Producers),
				string.Join(' ', item.ProductionCompanies),
				string.Join(' ', item.Cast),
				string.Join(' ', item.Directors),
				ratingsKeys,
				string.Join(' ', episodeText)
			}).ToLowerInvariant();

		return combined.Contains(term, StringComparison.Ordinal);
	}

	private void HandleSearchChanged()
	{
		InvokeAsync(StateHasChanged);
	}

	private static bool HasVisibleRatings(SeriesRatings ratings)
	{
		return ratings.Imdb is not null
			|| ratings.RottenTomatoes is not null
			|| ratings.Metacritic is not null
			|| ratings.UserAverage is not null;
	}

	private static string GetRatingsKeys(SeriesRatings ratings)
	{
		var keys = new List<string>();

		if (ratings.Imdb is not null)
		{
			keys.Add("imdb");
		}

		if (ratings.RottenTomatoes is not null)
		{
			keys.Add("rotten_tomatoes");
		}

		if (ratings.Metacritic is not null)
		{
			keys.Add("metacritic");
		}

		if (ratings.UserAverage is not null)
		{
			keys.Add("user_average");
		}

		return string.Join(' ', keys);
	}
}
