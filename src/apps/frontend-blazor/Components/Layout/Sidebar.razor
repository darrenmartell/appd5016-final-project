<aside class="@GetSidebarClass() relative bg-[#1a1a1a] border-r border-[#333] transition-all duration-300 ease-in-out h-screen">
    <button type="button"
            class="absolute -right-3 top-4 w-6 h-6 flex items-center justify-center rounded-full bg-[#333] text-[#b3b3b3] hover:bg-[#444] transition-colors cursor-pointer focus:outline-none z-10"
            @onclick="() => OnToggle.InvokeAsync()"
            aria-label="Toggle sidebar">
        <i class="fa-solid @(IsCollapsed ? "fa-chevron-right" : "fa-chevron-left")" aria-hidden="true"></i>
    </button>

    <nav class="mt-5 px-2" aria-label="Admin sections">
        <ul class="space-y-1">
            <SidebarItem Href="/admin/home" Label="Dashboard" IconClass="fa-chart-pie" Match="NavLinkMatch.All" IsCollapsed="IsCollapsed" />
            <SidebarItem Href="/admin/users" Label="User Management" IconClass="fa-users" Match="NavLinkMatch.All" IsCollapsed="IsCollapsed" />
            <SidebarItem Href="/admin/series" Label="Series" IconClass="fa-film" Match="NavLinkMatch.All" IsCollapsed="IsCollapsed" />
        </ul>
    </nav>
</aside>

@code {
    [Parameter]
    public bool IsCollapsed { get; set; }

    [Parameter]
    public EventCallback OnToggle { get; set; }

    private string GetSidebarClass()
    {
        return IsCollapsed ? "w-16" : "w-64";
    }
}